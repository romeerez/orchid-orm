{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "check": {
      "env": ["ADAPTER"]
    },
    "bun:check": {},
    "check:coverage": {
      "env": ["ADAPTER"],
      "outputs": ["coverage/**"]
    },
    "types": {},
    "build": {
      // https://github.com/romeerez/orchid-orm/issues/711
      // the `dependsOn` instructs turborepo to build package dependencies first
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {},
    "lint:check": {},
    "fmt": {},
    "fmt:check": {}
  }
}
