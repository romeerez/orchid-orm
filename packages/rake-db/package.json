{
  "name": "rake-db",
  "version": "2.32.0",
  "description": "Migrations tool for Postgresql DB",
  "keywords": [
    "migration",
    "migrations",
    "pg",
    "postgres",
    "postgresql"
  ],
  "homepage": "https://orchid-orm.netlify.app/guide/migration-setup-and-overview.html",
  "license": "ISC",
  "author": "Roman Kushyn",
  "repository": {
    "type": "git",
    "url": "https://github.com/romeerez/orchid-orm.git",
    "directory": "packages/rake-db"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./node-postgres": {
      "require": "./dist/node-postgres.js",
      "import": "./dist/node-postgres.mjs",
      "types": "./dist/node-postgres.d.ts"
    },
    "./postgres-js": {
      "require": "./dist/postgres-js.js",
      "import": "./dist/postgres-js.mjs",
      "types": "./dist/postgres-js.d.ts"
    }
  },
  "scripts": {
    "db": "tsx app/db-script.ts",
    "prompt": "tsx src/prompt.ts",
    "test": "jest --watch --verbose false",
    "check": "jest",
    "types": "tsc",
    "test:ci": "jest --coverage --coverageReporters json-summary",
    "build": "rm -rf ./dist/ && rollup -c ./rollup.config.mjs",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "pqb": "workspace:*",
    "prompts": "2.4.2"
  },
  "devDependencies": {
    "@types/prompts": "2.4.9",
    "test-utils": "workspace:*"
  }
}
